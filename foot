#!/bin/bash

# --- 🪄 MAGIC DOS2UNIX AUTO-FIX (Anti-Shake/Blink) ---
if grep -q $'\r' "$0"; then
    echo -e "\e[33m[*] Fixing Windows Line Endings automatically...\e[0m"
    sed -i 's/\r$//' "$0"
    exec bash "$0" "$@"
fi
# ----------------------------------------------------

# Colors for design
GREEN="\e[32m"
RED="\e[31m"
BLUE="\e[34m"
YELLOW="\e[33m"
CYAN="\e[36m"
MAGENTA="\e[35m"
RESET="\e[0m"

BASE_DIR="/var/www/html"

# ⚙️ কনফিগারেশন
DB_NAME="codexaum_erp"
DB_USER="ssk"
DB_PASS='babajalpesh$$1'

# =================================================================
# 🔍 SHARED HELPER: AUTO-DETECT PROJECTS & SELECT BY SL NO
# =================================================================
select_project() {
    echo -e "\n${YELLOW}[*] SCANNING VPS FOR RUNNING PROJECTS...${RESET}"
    cd "$BASE_DIR" || return 1
    
    shopt -s nullglob
    local ALL_DIRS=(*/)
    shopt -u nullglob

    PROJ_LIST=()
    for d in "${ALL_DIRS[@]}"; do
        d=${d%/} 
        if [[ "$d" != *"_baseline_safe"* && "$d" != "phpmyadmin" ]]; then
            PROJ_LIST+=("$d")
        fi
    done

    if [ ${#PROJ_LIST[@]} -eq 0 ]; then
        echo -e "${RED}[-] No active projects found!${RESET}"
        return 1
    fi

    echo -e "${CYAN}Available Projects on this VPS:${RESET}"
    echo -e "${BLUE}-----------------------------------------------------${RESET}"
    for i in "${!PROJ_LIST[@]}"; do
        echo -e "${GREEN}  $((i+1))) 📁 ${PROJ_LIST[$i]}${RESET}"
    done
    echo -e "${BLUE}-----------------------------------------------------${RESET}"
    echo -e "${RED}  0) 🔙 Cancel & Go Back${RESET}"

    read -p "Select a Project SL No [0-${#PROJ_LIST[@]}]: " P_CHOICE
    P_CHOICE=$(echo "$P_CHOICE" | tr -cd '0-9')

    if [[ -z "$P_CHOICE" || "$P_CHOICE" == "0" ]]; then
        return 1
    elif [[ "$P_CHOICE" -gt 0 && "$P_CHOICE" -le "${#PROJ_LIST[@]}" ]]; then
        SELECTED_PROJ="${PROJ_LIST[$((P_CHOICE-1))]}"
        PROJECT_DIR="$BASE_DIR/$SELECTED_PROJ"
        BACKUP_DIR="$BASE_DIR/${SELECTED_PROJ}_baseline_safe"
        FOOTPRINT_FILE="$BASE_DIR/${SELECTED_PROJ}_footprint.md5"
        INFO_FILE="$BASE_DIR/${SELECTED_PROJ}_backup_info.txt"
        
        echo -e "${GREEN}[+] Selected Project: ${CYAN}$SELECTED_PROJ${RESET}"
        return 0
    else
        echo -e "${RED}[-] Invalid Selection!${RESET}"
        return 1
    fi
}

# ═══════════════════════════════════════════════════════
#                      MAIN LOOP
# ═══════════════════════════════════════════════════════
while true; do
    clear
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${MAGENTA}             🛡️ MADE BY PRODIP 🛡️              ${RESET}"
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${GREEN}    🌟 VPS MULTI-PROJECT SELF-HEALING PRO 🌟       ${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"
    echo -e "${CYAN}1) 📸 TAKE FOOTPRINT (Select Project & Backup)${RESET}"
    echo -e "${YELLOW}2) 🕵️‍♂️ SCAN FOR CHANGES (Check Errors/Hacks)${RESET}"
    echo -e "${RED}3) 🚑 AUTO-RESTORE (1-Click Rollback)${RESET}"
    echo -e "${MAGENTA}4) ℹ️ VIEW FOOTPRINT INFO (Date & Status)${RESET}"
    echo -e "${GREEN}5) 🚀 FULL AUTO-MAGIC (Hide .PHP + Auto Edit Files)${RESET}"
    echo -e "${BLUE}-----------------------------------------------------${RESET}"
    echo -e "${RED}0) ❌ EXIT${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"

    read -p "Select an option [0-5]: " raw_choice
    choice=$(echo "$raw_choice" | tr -cd '0-9')
    if [ -z "$choice" ]; then choice="99"; fi

    case $choice in
        1)
            if select_project; then
                echo -e "\n${YELLOW}[*] CREATING BASELINE FOOTPRINT...${RESET}"
                sudo rm -rf "$BACKUP_DIR"
                sudo cp -r "$PROJECT_DIR" "$BACKUP_DIR"
                sudo find "$PROJECT_DIR" -type f -name "*.php" -exec md5sum {} + | sudo tee "$FOOTPRINT_FILE" > /dev/null
                sudo mysqldump -u "$DB_USER" -p"$DB_PASS" --no-tablespaces --no-data --skip-comments --skip-dump-date "$DB_NAME" 2>/dev/null | sed 's/ AUTO_INCREMENT=[0-9]*//g' > "$BACKUP_DIR/db_structure.sql"
                CURRENT_DATE=$(TZ="Asia/Kolkata" date +"%d %B %Y, %I:%M:%S %p")
                echo "Project Name: $SELECTED_PROJ" > "$INFO_FILE"
                echo "Last Footprint Taken: $CURRENT_DATE" >> "$INFO_FILE"
                echo "Backup Path: $BACKUP_DIR" >> "$INFO_FILE"
                echo -e "${GREEN}[+] FOOTPRINT SAVED SUCCESSFULLY!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;
        2)
            if select_project; then
                echo -e "\n${YELLOW}[*] SCANNING FOR CORRUPTION...${RESET}"
                if [ ! -f "$FOOTPRINT_FILE" ]; then
                    echo -e "${RED}[-] No footprint found! Run Option 1 first.${RESET}"
                else
                    if md5sum -c "$FOOTPRINT_FILE" --quiet > /tmp/corrupted_files.txt 2>&1; then
                        echo -e "${GREEN}[+] SUCCESS: All files are intact!${RESET}"
                    else
                        echo -e "${RED}[!] WARNING: CHANGES DETECTED IN FILES!${RESET}"
                        cat /tmp/corrupted_files.txt | grep "FAILED" | awk -F':' '{print " 👉 " $1}'
                    fi
                fi
            fi
            read -p "Press Enter to return..."
            ;;
        3)
            if select_project; then
                if [ ! -d "$BACKUP_DIR" ]; then
                    echo -e "${RED}[-] No backup vault found!${RESET}"
                else
                    read -p "Are you sure you want to RESTORE? (YES/no): " CONFIRM
                    if [ "$CONFIRM" == "YES" ]; then
                        sudo cp -a "$BACKUP_DIR/." "$PROJECT_DIR/"
                        sudo chown -R $USER:www-data "$PROJECT_DIR"
                        sudo chmod -R 775 "$PROJECT_DIR"
                        echo -e "${GREEN}[+] RESTORED SUCCESSFULLY!${RESET}"
                    fi
                fi
            fi
            read -p "Press Enter to return..."
            ;;
        4)
            if select_project; then
                if [ -f "$INFO_FILE" ]; then
                    cat "$INFO_FILE" | while read line; do echo -e "${YELLOW}👉 $line${RESET}"; done
                else
                    echo -e "${RED}[-] No footprint data found.${RESET}"
                fi
            fi
            read -p "Press Enter to return..."
            ;;

        # 💥 NEW MEGA FEATURE: FULL AUTO-MAGIC 💥
        5)
            if select_project; then
                echo -e "\n${YELLOW}[*] INITIATING FULL AUTO-MAGIC FOR '$SELECTED_PROJ'...${RESET}"
                
                # --- STEP 1: NGINX REBUILD MAGIC ---
                echo -e "\n${CYAN}[1/2] Auto-configuring Nginx Server...${RESET}"
                NGINX_CONF=$(sudo grep -rl "root /var/www/html/$SELECTED_PROJ" /etc/nginx/sites-available/ | head -n 1)
                
                if [ -z "$NGINX_CONF" ]; then
                    echo -e "${RED}[-] Nginx config not found! Skipping Nginx part.${RESET}"
                else
                    sudo cp "$NGINX_CONF" "${NGINX_CONF}.magic_backup"
                    
                    # Extract variables like a Pro
                    SERVER_NAME=$(sudo awk '/server_name/ {print $0}' "$NGINX_CONF" | head -n 1)
                    ROOT_DIR=$(sudo awk '/root/ {print $0}' "$NGINX_CONF" | head -n 1)
                    PHP_SOCK=$(sudo awk '/fastcgi_pass/ {print $0}' "$NGINX_CONF" | head -n 1)
                    
                    # Create a perfect, bulletproof config
                    sudo tee "$NGINX_CONF" > /dev/null <<EOF
server {
    listen 80;
    $SERVER_NAME
    $ROOT_DIR
    index index.php index.html;

    location / {
        try_files \$uri \$uri/ @php;
    }

    location @php {
        rewrite ^/(.*)$ /\$1.php last;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        $PHP_SOCK
    }
}
EOF
                    if sudo nginx -t >/dev/null 2>&1; then
                        sudo systemctl restart nginx
                        echo -e "${GREEN}[+] Nginx Rebuilt & Restarted! Server is now Extensionless. 🚀${RESET}"
                    else
                        echo -e "${RED}[!] Nginx Syntax Error. Rolling back safely...${RESET}"
                        sudo mv "${NGINX_CONF}.magic_backup" "$NGINX_CONF"
                        sudo systemctl restart nginx
                    fi
                fi

                # --- STEP 2: VS CODE AUTO-EDIT MAGIC ---
                echo -e "\n${CYAN}[2/2] Auto-Removing .php from all project files...${RESET}"
                FILE_COUNT=$(find "$PROJECT_DIR" -type f -name "*.php" | wc -l)
                echo -e "${YELLOW}[*] Found $FILE_COUNT PHP files. Processing at light speed...${RESET}"
                
                find "$PROJECT_DIR" -type f -name "*.php" | while read -r file; do
                    # Double Quotes Link & Form
                    sudo sed -i -E 's/href="([^"]+)\.php([^"]*)"/href="\1\2"/g' "$file"
                    sudo sed -i -E 's/action="([^"]+)\.php([^"]*)"/action="\1\2"/g' "$file"
                    
                    # Single Quotes Link & Form
                    sudo sed -i -E "s/href='([^']+)\.php([^']*)'/href='\1\2'/g" "$file"
                    sudo sed -i -E "s/action='([^']+)\.php([^']*)'/action='\1\2'/g" "$file"
                    
                    # Double Quotes Header Redirect
                    sudo sed -i -E 's/header\("Location:\s*([^"]+)\.php([^"]*)"\)/header("Location: \1\2")/g' "$file"
                    
                    # Single Quotes Header Redirect
                    sudo sed -i -E "s/header\('Location:\s*([^']+)\.php([^']*)'\)/header('Location: \1\2')/g" "$file"
                done
                
                echo -e "${GREEN}[+] BOOM! 💥 All $FILE_COUNT files edited. 100% VS Code Magic applied automatically!${RESET}"
                echo -e "${MAGENTA}💡 TIP: Clear your browser cache or use Incognito to see the magic!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;

        0)
            clear
            echo -e "${GREEN}Exiting. Stay secure, Prodip Bandhu!${RESET}"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid Option!${RESET}"
            sleep 1
            ;;
    esac
done
