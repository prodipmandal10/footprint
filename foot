#!/bin/bash

# --- 🪄 MAGIC DOS2UNIX AUTO-FIX (Anti-Shake/Blink) ---
if grep -q $'\r' "$0"; then
    echo -e "\e[33m[*] Fixing Windows Line Endings automatically...\e[0m"
    sed -i 's/\r$//' "$0"
    exec bash "$0" "$@"
fi
# ----------------------------------------------------

# Colors for design
GREEN="\e[32m"
RED="\e[31m"
BLUE="\e[34m"
YELLOW="\e[33m"
CYAN="\e[36m"
MAGENTA="\e[35m"
RESET="\e[0m"

# ⚙️ কনফিগারেশন (আপনার প্রজেক্টের পাথ এবং ডাটাবেস)
PROJECT_DIR="/var/www/html/codexaum"
BACKUP_DIR="/var/www/html/codexaum_baseline_safe"
FOOTPRINT_FILE="/var/www/html/codexaum_footprint.md5"

DB_NAME="codexaum_erp"
DB_USER="ssk"
DB_PASS='babajalpesh$$1' # Single quote used to prevent bash evaluation of $$

# ═══════════════════════════════════════════════════════
#                      MAIN LOOP
# ═══════════════════════════════════════════════════════
while true; do
    clear
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${MAGENTA}             🛡️ MADE BY PRODIP 🛡️              ${RESET}"
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${GREEN}    🌟 SELF-HEALING & SECURITY MONITOR (PRO) 🌟    ${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"
    echo -e "${CYAN}1) 📸 TAKE FOOTPRINT (Save Good State & Backup)${RESET}"
    echo -e "${YELLOW}2) 🕵️‍♂️ SCAN FOR CHANGES (Check Hacks or Errors)${RESET}"
    echo -e "${RED}3) 🚑 AUTO-RESTORE (1-Click Rollback to Safe State)${RESET}"
    echo -e "${BLUE}-----------------------------------------------------${RESET}"
    echo -e "${RED}0) ❌ EXIT${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"

    read -p "Select an option [0-3]: " raw_choice
    choice=$(echo "$raw_choice" | tr -cd '0-9')
    if [ -z "$choice" ]; then choice="99"; fi

    case $choice in
        1)
            echo -e "\n${YELLOW}[*] CREATING BASELINE FOOTPRINT & BACKUP...${RESET}"
            
            # ১. ফাইল ব্যাকআপ নেওয়া
            echo -e "${CYAN}[*] Cloning current healthy files to Secret Vault...${RESET}"
            sudo rm -rf "$BACKUP_DIR"
            sudo cp -r "$PROJECT_DIR" "$BACKUP_DIR"
            
            # ২. MD5 ফুটপ্রিন্ট নেওয়া
            echo -e "${CYAN}[*] Generating MD5 Hashes for Security...${RESET}"
            sudo find "$PROJECT_DIR" -type f -name "*.php" -exec md5sum {} + | sudo tee "$FOOTPRINT_FILE" > /dev/null
            
            # ৩. ডাটাবেস স্ট্রাকচার ব্যাকআপ (শুধু ছক, ডেটা নয়)
            echo -e "${CYAN}[*] Exporting Database Structure...${RESET}"
            sudo mysqldump -u "$DB_USER" -p"$DB_PASS" --no-data "$DB_NAME" > "$BACKUP_DIR/db_structure.sql" 2>/dev/null
            
            echo -e "${GREEN}[+] FOOTPRINT SAVED! Server is now monitored.${RESET}"
            read -p "Press Enter to return..."
            ;;

        2)
            echo -e "\n${YELLOW}[*] SCANNING SERVER FOR CORRUPT FILES OR HACKS...${RESET}"
            if [ ! -f "$FOOTPRINT_FILE" ]; then
                echo -e "${RED}[-] No footprint found! Please run Option 1 first.${RESET}"
            else
                echo -e "${CYAN}[*] Verifying MD5 Checksums...${RESET}"
                
                # Check quiet output to see if there's any error
                if md5sum -c "$FOOTPRINT_FILE" --quiet > /tmp/corrupted_files.txt 2>&1; then
                    echo -e "${GREEN}[+] SUCCESS: All files are intact! No hacks or corruption detected.${RESET}"
                else
                    echo -e "${RED}[!] WARNING: CHANGES DETECTED!${RESET}"
                    echo -e "${YELLOW}The following files have been modified or corrupted:${RESET}"
                    cat /tmp/corrupted_files.txt | grep "FAILED" | awk -F':' '{print " 👉 " $1}'
                    echo -e "\n${CYAN}💡 TIP: If you did not make these changes, use Option 3 to Auto-Restore!${RESET}"
                fi
            fi
            read -p "Press Enter to return..."
            ;;

        3)
            echo -e "\n${RED}=====================================================${RESET}"
            echo -e "${MAGENTA} 🚑 AUTO-RESTORE INITIATED (ROLLBACK TO SAFE STATE)${RESET}"
            echo -e "${RED}=====================================================${RESET}"
            if [ ! -d "$BACKUP_DIR" ]; then
                echo -e "${RED}[-] No backup vault found! Cannot restore.${RESET}"
                read -p "Press Enter to return..."
                continue
            fi
            
            read -p "Are you sure you want to OVERWRITE current files with Safe Backup? (YES/no): " CONFIRM
            if [ "$CONFIRM" == "YES" ]; then
                echo -e "${YELLOW}[*] Restoring files from Secret Vault...${RESET}"
                
                # ফাইলগুলো কপি করে রিপ্লেস করা
                sudo cp -a "$BACKUP_DIR/." "$PROJECT_DIR/"
                
                # পারমিশন ঠিক করা
                sudo chown -R $USER:www-data "$PROJECT_DIR"
                sudo chmod -R 775 "$PROJECT_DIR"
                
                echo -e "${CYAN}[*] Database structure checked... (Data kept safe)${RESET}"
                
                echo -e "${GREEN}[+] SERVER RESTORED SUCCESSFULLY! Your site is healthy again.${RESET}"
            else
                echo -e "${YELLOW}[*] Restore Cancelled.${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;

        0)
            clear
            echo -e "${GREEN}Exiting Self-Healing Tool. Stay secure, Prodip Bandhu!${RESET}"
            exit 0
            ;;

        *)
            echo -e "${RED}Invalid Option!${RESET}"
            sleep 1
            ;;
    esac
done
